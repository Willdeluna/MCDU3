{
  "name": "virtual-cdu",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "src",
    "server"
  ],
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "vite build",
    "preview": "vite preview",
    "server": "cd server && npm run dev",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "npm run typecheck -w shared && npm run typecheck -w src && npm run typecheck -w server",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --project=desktop-chromium --grep=\"@smoke\"",
    "test:e2e:visual": "playwright test e2e/visual-navigation-display.spec.ts --project=desktop-chromium",
    "test:e2e:full": "playwright test",
    "test:e2e:smoke": "playwright test --project=desktop-chromium --grep=\"@smoke\"",
    "test:visual": "playwright test --grep=\"Visual Regression\"",
    "test:visual:update": "playwright test --grep=\"Visual Regression\" --update-snapshots",
    "check:status-docs": "node scripts/check-status-docs.mjs",
    "measure:visual": "node scripts/measure-visual-fidelity.mjs",
    "capture:baseline": "CAPTURE_BASELINE=1 playwright test e2e/baseline-screenshots.spec.ts --project=chromium",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^6.0.0",
    "vite": "^8.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5",
    "workbox-build": "^7.4.1",
    "workbox-core": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "workbox-window": "^7.4.1"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
